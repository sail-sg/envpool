diff --git a/cmake/OpenCVUtils.cmake b/cmake/OpenCVUtils.cmake
--- a/cmake/OpenCVUtils.cmake
+++ b/cmake/OpenCVUtils.cmake
@@ -448,8 +448,15 @@ set(OCV_COMPILER_FAIL_REGEX
     "command option .* is not recognized"       # XL
     "not supported in this configuration, ignored"       # AIX (';' is replaced with ',')
     "File with unknown suffix passed to linker" # PGI
     "WARNING: unknown flag:"                    # Open64
   )
+
+if(MSVC AND DEFINED CMAKE_TOOLCHAIN_FILE AND CMAKE_TOOLCHAIN_FILE MATCHES "crosstool_bazel")
+  # Bazel's Windows toolchain forwards a few GNU-style optimization flags into
+  # try_compile() checks. MSVC warns about them (D9002), but the probed flag
+  # itself may still be valid, so don't treat those warnings as hard failures.
+  list(REMOVE_ITEM OCV_COMPILER_FAIL_REGEX "ignoring unknown option" "warning D9002")
+endif()
 
 MACRO(ocv_check_compiler_flag LANG FLAG RESULT)
   set(_fname "${ARGN}")
   if(NOT DEFINED ${RESULT})
