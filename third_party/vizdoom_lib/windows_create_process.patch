+        std::string quoteCommandArg(const std::string &arg) {
+            if (arg.empty()) return "\"\"";
+            if (arg.find_first_of(" \t\"") == std::string::npos) return arg;
+
+            std::string quoted = "\"";
+            size_t backslashes = 0;
+            for (char ch : arg) {
+                if (ch == '\\') {
+                    ++backslashes;
+                } else if (ch == '"') {
+                    quoted.append(backslashes * 2 + 1, '\\');
+                    quoted.push_back('"');
+                    backslashes = 0;
+                } else {
+                    quoted.append(backslashes, '\\');
+                    backslashes = 0;
+                    quoted.push_back(ch);
+                }
+            }
+            quoted.append(backslashes * 2, '\\');
+            quoted.push_back('"');
+            return quoted;
+        }
+    }
